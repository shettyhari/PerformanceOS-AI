datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  // Relations
  memberships   OrgMember[]
  auditLogs     AuditLog[]
  tasks         Task[]
  apiKeys       APIKey[]
  conversations AIConversation[]
  sessions      Session[]
  notifications Notification[]
}

model Organization {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  members           OrgMember[]
  integrations      Integration[]
  windsorConnection WindsorConnection?
  adAccounts        AdAccount[]
  alerts            Alert[]
  crmLeads          CRMLead[]
  goals             Goal[]
  forecasts         Forecast[]
  settings          Settings?
  featureFlags      FeatureFlag[]
  webhooks          Webhook[]
  conversations     AIConversation[]
  revenue           Revenue[]
  tasks             Task[]
  activities        Activity[]
  apiKeys           APIKey[]
  reports           Report[]
}

model OrgMember {
  id             String       @id @default(uuid())
  orgId          String
  userId         String
  roleId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique // e.g. "OWNER", "ADMIN", "MEMBER", "VIEWER"
  permissions RolePermission[]
  memberships OrgMember[]
}

model Permission {
  id    String           @id @default(uuid())
  name  String           @unique // e.g. "campaigns:read", "campaigns:write"
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Integration {
  id                   String       @id @default(uuid())
  orgId                String
  platform             String       // e.g. "GOOGLE_ADS", "META_ADS", "LINKEDIN_ADS", "MS_ADS", "GA4", "GTM", "GSC"
  status               String       @default("ACTIVE") // ACTIVE, ERROR, INACTIVE
  credentialsEncrypted String       @db.Text
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, platform])
  @@index([orgId])
}

model WindsorConnection {
  id               String       @id @default(uuid())
  orgId            String       @unique
  apiKeyEncrypted  String       @db.Text
  syncStatus       String       @default("PENDING") // SUCCESS, FAILED, SYNCING, PENDING
  lastSyncAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  syncLogs         SyncLog[]

  @@index([orgId])
}

model AdAccount {
  id                String       @id @default(uuid())
  orgId             String
  platform          String       // GOOGLE_ADS, META_ADS, etc.
  externalAccountId String
  name              String
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns         Campaign[]

  @@unique([orgId, platform, externalAccountId])
  @@index([orgId])
}

model Campaign {
  id                 String       @id @default(uuid())
  adAccountId        String
  externalCampaignId String
  name               String
  status             String
  budgetType         String?
  budgetAmount       Decimal?     @db.Decimal(12, 2)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  adAccount          AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  metrics            Metric[]
  crmLeads           CRMLead[]
  attributions       Attribution[]

  @@unique([adAccountId, externalCampaignId])
  @@index([adAccountId])
}

model Metric {
  id          String   @id @default(uuid())
  campaignId  String
  date        DateTime @db.Date
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  leads       Int      @default(0)
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

model Attribution {
  id              String       @id @default(uuid())
  campaignId      String
  leadId          String
  touchpointDate  DateTime
  attributionType String       // FIRST_TOUCH, LAST_TOUCH, LINEAR
  weight          Decimal      @db.Decimal(5, 4)
  createdAt       DateTime     @default(now())

  campaign        Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead            CRMLead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([leadId])
}

model Report {
  id              String       @id @default(uuid())
  orgId           String
  name            String
  format          String       // PDF, EXCEL, PPT
  schedule        String       // DAILY, WEEKLY, MONTHLY, MANUAL
  delivery        String[]     // EMAIL, WHATSAPP, TELEGRAM
  recipients      String[]
  lastGeneratedAt DateTime?
  createdAt       DateTime     @default(now())

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Alert {
  id         String       @id @default(uuid())
  orgId      String
  type       String       // ROAS_DROP, CPA_SPIKE, BUDGET_EXHAUSTION, CTR_DROP
  severity   String       // INFO, WARNING, CRITICAL
  message    String
  isResolved Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([createdAt])
}

model AIConversation {
  id        String       @id @default(uuid())
  orgId     String
  userId    String
  title     String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIMessage[]

  @@index([orgId])
  @@index([userId])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String         // user, assistant, system
  content        String         @db.Text
  toolCalls      Json?
  createdAt      DateTime       @default(now())

  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Task {
  id          String       @id @default(uuid())
  orgId       String
  assignedTo  String?
  title       String
  description String?      @db.Text
  status      String       @default("TODO") // TODO, IN_PROGRESS, DONE
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([assignedTo])
}

model Activity {
  id          String       @id @default(uuid())
  orgId       String
  userId      String
  description String
  createdAt   DateTime     @default(now())

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  timestamp  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model CRMLead {
  id         String       @id @default(uuid())
  orgId      String
  email      String?
  name       String
  source     String?      // google, facebook, etc.
  campaignId String?
  status     String       @default("NEW") // NEW, CONTACTED, QUALIFIED, PROPOSAL, WON, LOST
  revenue    Decimal      @default(0) @db.Decimal(12, 2)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign   Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  attributions Attribution[]

  @@index([orgId])
  @@index([campaignId])
}

model Revenue {
  id        String       @id @default(uuid())
  orgId     String
  amount    Decimal      @db.Decimal(12, 2)
  source    String       // CRM, Shopify, Stripe, Manual
  date      DateTime
  createdAt DateTime     @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([date])
}

model Goal {
  id        String       @id @default(uuid())
  orgId     String
  metric    String       // ROAS, SPEND, REVENUE, CONVERSIONS
  target    Decimal      @db.Decimal(12, 2)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime     @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Forecast {
  id             String       @id @default(uuid())
  orgId          String
  metric         String
  predictedValue Decimal      @db.Decimal(12, 2)
  confidenceLower Decimal     @db.Decimal(12, 2)
  confidenceUpper Decimal     @db.Decimal(12, 2)
  date           DateTime
  createdAt      DateTime     @default(now())

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([date])
}

model SyncLog {
  id                 String            @id @default(uuid())
  windsorConnectionId String
  status             String            // SUCCESS, FAILED
  errorMessage       String?           @db.Text
  rowsSynced         Int
  timestamp          DateTime          @default(now())

  connection         WindsorConnection @relation(fields: [windsorConnectionId], references: [id], onDelete: Cascade)

  @@index([windsorConnectionId])
  @@index([timestamp])
}

model Settings {
  id        String       @id @default(uuid())
  orgId     String       @unique
  theme     String       @default("system") // dark, light, system
  currency  String       @default("USD")
  timezone  String       @default("UTC")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model FeatureFlag {
  id        String       @id @default(uuid())
  orgId     String
  key       String
  enabled   Boolean      @default(false)
  createdAt DateTime     @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@index([orgId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model APIKey {
  id        String       @id @default(uuid())
  orgId     String
  userId    String
  name      String
  keyHash   String       @unique
  createdAt DateTime     @default(now())
  expiresAt DateTime?

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
}

model Webhook {
  id        String       @id @default(uuid())
  orgId     String
  url       String
  secret    String
  events    String[]
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}
